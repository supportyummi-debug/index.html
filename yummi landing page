<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>YUMMI - Homemade Food Back Home | Qatar</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Custom Fonts (Quicksand for its friendly, rounded feel) -->
    <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@400;500;600;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        'yummi-brown': '#432115', // From logo text
                        'yummi-orange': '#F9A458', // From logo smile
                        'yummi-red': '#CD3C3C',    // From logo heart
                        'yummi-almond': '#FDF3E7',  // Logo background
                        'yummi-vanilla': '#FFFFFF' // Clean white
                    },
                    fontFamily: {
                        sans: ['Quicksand', 'sans-serif'],
                    },
                }
            }
        }
    </script>
</head>
<body class="bg-yummi-vanilla text-yummi-brown font-sans antialiased">

    <!-- Header / Navbar -->
    <header class="sticky top-0 z-50 bg-yummi-vanilla/95 backdrop-blur-sm shadow-sm border-b border-yummi-brown/10">
        <nav class="max-w-7xl mx-auto px-6 py-3 flex items-center justify-between">
            <a href="#" class="flex items-center gap-2">
                <!-- LOGO IMAGE - Referencing image_0.png -->
                <img src="image_0.png" alt="YUMMI Logo" class="h-14 w-auto">
                <span class="sr-only">YUMMI Home</span>
            </a>
            <div class="hidden md:flex items-center gap-6 font-medium text-yummi-brown">
                <a href="#story" class="hover:text-yummi-orange transition">Our Story</a>
                <a href="#how" class="hover:text-yummi-orange transition">How It Works</a>
                <a href="#faq" class="hover:text-yummi-orange transition">FAQ</a>
                <a href="#join" class="bg-yummi-orange text-white px-5 py-2.5 rounded-full text-sm font-semibold hover:bg-yummi-orange/90 transition shadow">Join Waitlist</a>
            </div>
            <!-- Mobile Menu Placeholder (hidden on desktop) -->
            <button class="md:hidden text-yummi-brown text-2xl">
                <i class="fa-solid fa-bars"></i>
            </button>
        </nav>
    </header>

    <!-- Hero Section -->
    <section class="bg-gradient-to-b from-yummi-almond to-yummi-vanilla pt-16 pb-24 text-center">
        <div class="max-w-5xl mx-auto px-6 space-y-8">
            <div class="flex justify-center">
                <!-- Using a smile emoji for a friendly touch -->
                <span class="text-6xl">😊</span>
            </div>
            <h1 class="text-5xl md:text-6xl font-bold leading-tight text-yummi-brown tracking-tight">
                Bringing Homemade <span class="text-yummi-orange">Food</span> Back Home.
            </with>
            <p class="text-xl text-yummi-brown/90 max-w-2xl mx-auto leading-relaxed">
                Craving the warmth of a real home-cooked meal? YUMMI connects you with certified local home cooks across Qatar, ready to share their family secrets.
            </p>
            <div id="join" class="max-w-lg mx-auto bg-white p-2 rounded-full shadow-lg border border-yummi-brown/10 flex flex-col sm:flex-row gap-2">
                <input type="email" placeholder="Your best email address" class="w-full px-6 py-3 rounded-full text-lg placeholder-yummi-brown/50 focus:ring-2 focus:ring-yummi-orange transition bg-yummi-almond/30">
                <button class="bg-yummi-orange text-white px-8 py-3 rounded-full text-lg font-bold hover:bg-yummi-orange/90 transition shadow-md whitespace-nowrap">Notify Me</button>
            </div>
            <p class="text-sm text-yummi-brown/60">Be the first to know when we launch and get an exclusive founder's discount!</p>
        </div>
    </section>

    <!-- Brand Story & Ashraf Story Sections -->
    <section id="story" class="py-24 bg-white">
        <div class="max-w-6xl mx-auto px-6 grid md:grid-cols-2 gap-16 items-start">
            
            <!-- Ashraf Story Card -->
            <div class="bg-yummi-almond p-10 rounded-3xl border-2 border-yummi-orange shadow-inner space-y-6">
                <div class="flex items-center gap-4">
                    <span class="text-4xl text-yummi-orange">🧡</span>
                    <h2 class="text-3xl font-semibold text-yummi-brown">Meet Ashraf</h2>
                </div>
                <p class="text-lg leading-relaxed text-yummi-brown/90">
                    A man like millions living away from home, missing his mother's homemade food after a long day. Restaurants are everywhere, but the warmth of a home-cooked meal is hard to find. That's why I created YUMMI—an app that connects licensed home cooks with people craving authentic homemade meals across Qatar.
                </p>
            </div>

            <!-- Founder & Mission Card -->
            <div class="bg-yummi-vanilla p-10 rounded-3xl shadow-xl border border-yummi-brown/10 space-y-6">
                <div class="flex items-center gap-4">
                    <span class="text-4xl text-yummi-brown">👋</span>
                    <h2 class="text-3xl font-semibold text-yummi-brown">I'm Hamid</h2>
                </div>
                <p class="text-lg leading-relaxed text-yummi-brown/90">
                    A Grade 9 student and founder of YUMMI. I created YUMMI to solve a simple problem: thousands of people in Qatar miss the comfort of homemade food. My goal is to support licensed home cooks while giving students, bachelors, and families easy access to fresh, authentic meals.
                </p>
                <div class="inline-flex items-center gap-3 px-4 py-1.5 rounded-full bg-yummi-brown/5 text-yummi-brown/70 text-sm font-medium">
                    <img src="image_0.png" alt="Small YUMMI logo" class="h-6">
                    Powered by the Spirit of Home
                </div>
            </div>
        </div>
    </section>

    <!-- How It Works Section -->
    <section id="how" class="py-24 bg-yummi-almond/50">
        <div class="max-w-6xl mx-auto px-6 text-center space-y-16">
            <h2 class="text-4xl font-bold text-yummi-brown">How It Works</h2>
            <div class="grid sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5 gap-8">
                <!-- Steps with simple icons and brown text matching your logo -->
                <div class="step-card bg-white p-6 rounded-2xl shadow-sm border border-yummi-brown/5">
                    <div class="w-16 h-16 rounded-full bg-yummi-brown/5 flex items-center justify-center text-4xl mx-auto mb-6">🍛</div>
                    <h4 class="font-semibold text-xl text-yummi-brown mb-2">Browse Meals</h4>
                    <p class="text-yummi-brown/80 text-sm">Discover amazing, authentic dishes made by certified cooks.</p>
                </div>
                <div class="step-card bg-white p-6 rounded-2xl shadow-sm border border-yummi-brown/5">
                    <div class="w-16 h-16 rounded-full bg-yummi-brown/5 flex items-center justify-center text-4xl mx-auto mb-6">📱</div>
                    <h4 class="font-semibold text-xl text-yummi-brown mb-2">Order Safely</h4>
                    <p class="text-yummi-brown/80 text-sm">Place your request through our secure mobile app.</p>
                </div>
                <div class="step-card bg-white p-6 rounded-2xl shadow-sm border border-yummi-brown/5">
                    <div class="w-16 h-16 rounded-full bg-yummi-brown/5 flex items-center justify-center text-4xl mx-auto mb-6">🚗</div>
                    <h4 class="font-semibold text-xl text-yummi-brown mb-2">Pickup or Deliver</h4>
                    <p class="text-yummi-brown/80 text-sm">Have it delivered or pick it up fresh yourself.</p>
                </div>
                <div class="step-card bg-white p-6 rounded-2xl shadow-sm border border-yummi-brown/5">
                    <div class="w-16 h-16 rounded-full bg-yummi-brown/5 flex items-center justify-center text-4xl mx-auto mb-6">🤍</div>
                    <h4 class="font-semibold text-xl text-yummi-brown mb-2">Enjoy Food</h4>
                    <p class="text-yummi-brown/80 text-sm">Savor the authentic taste of warmth and tradition.</p>
                </div>
                <div class="step-card bg-white p-6 rounded-2xl shadow-sm border border-yummi-brown/5">
                    <div class="w-16 h-16 rounded-full bg-yummi-brown/5 flex items-center justify-center text-4xl mx-auto mb-6">⭐</div>
                    <h4 class="font-semibold text-xl text-yummi-brown mb-2">Support Locals</h4>
                    <p class="text-yummi-brown/80 text-sm">Rate your experience and empower home cooks.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- FAQ Section (reusing the new color palette) -->
    <section id="faq" class="py-24 bg-white">
        <div class="max-w-3xl mx-auto px-6 space-y-16">
            <h2 class="text-4xl font-bold text-center text-yummi-brown">FAQ</h2>
            <div class="space-y-6">
                <details class="group bg-yummi-almond p-6 rounded-xl border border-yummi-orange cursor-pointer">
                    <summary class="flex items-center justify-between font-semibold text-lg text-yummi-brown">
                        Are the cooks licensed?
                        <span class="transition group-open:rotate-180">🔽</span>
                    </summary>
                    <p class="mt-4 text-yummi-brown/90 leading-relaxed text-sm">
                        Yes! Safety and quality are our top priorities. All home cooks on YUMMI must hold a valid, official cooking license in Qatar before they can join the platform and share their meals.
                    </p>
                </details>
                <details class="group bg-yummi-almond p-6 rounded-xl border border-yummi-orange cursor-pointer">
                    <summary class="flex items-center justify-between font-semibold text-lg text-yummi-brown">
                        When will the app launch?
                        <span class="transition group-open:rotate-180">🔽</span>
                    </summary>
                    <p class="mt-4 text-yummi-brown/90 leading-relaxed text-sm">
                        We are working incredibly hard behind the scenes to launch very soon. Sign up for our waitlist to get the exclusive invite as soon as we go live!
                    </p>
                </details>
            </div>
        </div>
    </section>

    <!-- Footer with the Red Accent -->
    <footer id="contact" class="bg-yummi-brown text-yummi-almond py-16 border-t border-yummi-red">
        <div class="max-w-7xl mx-auto px-6 grid md:grid-cols-2 gap-12 text-center md:text-left">
            <div class="space-y-4">
                <img src="image_0.png" alt="YUMMI Logo Footer" class="h-16 w-auto mx-auto md:mx-0">
                <p class="text-2xl font-bold">Bringing Homemade Food Back Home</p>
            </div>
            <div class="space-y-4 text-sm text-yummi-almond/80">
                <h3 class="text-white font-semibold text-lg">Connect</h3>
                <p>Have questions? <a href="mailto:your-email@example.com" class="text-yummi-red hover:underline font-medium">your-email@example.com</a></p>
                <p>Based in Qatar, serving the heart.</p>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-6 mt-12 pt-8 border-t border-yummi-almond/10 text-center text-xs text-yummi-almond/60">
            <p>&copy; 2026 YUMMI. All Rights Reserved.</p>
            <p class="mt-1">Designed by Hamid - Grade 9 Student Founder</p>
        </div>
    </footer>

    <!-- FontAwesome for the menu icon -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</body>
</html>
